generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = "mysql://root:@localhost:3306/quiz_feedback"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

model Survey {
  id               Int        @id @default(autoincrement())
  shop             String
  title            String
  isFrenchVersion  Boolean    @default(false)           // kept for backward-compat

  // ✅ NEW — supports "default" | "french" | "spanish" | "italian"
  language         String     @default("default")

  surveyId         Int?
  questions        Question[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([shop, title])
  @@index([shop])
  @@index([shop, language])   // ✅ NEW index — speeds up per-language lookups
}

model Question {
  id              Int       @id @default(autoincrement())
  text            String
  surveyId        Int
  survey          Survey    @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers         Answer[]
  isMultiChoice   Boolean   @default(false)
  isConditional   Boolean   @default(false)
  isTextBox       Boolean   @default(false)
  isSingle        Boolean   @default(false)
  conditionAnswer String?

  @@index([surveyId])
}

model Answer {
  id          Int      @id @default(autoincrement())
  text        String
  questionId  Int
  haveTextBox Boolean  @default(false)
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model ApiProxyData {
  id          Int      @id @default(autoincrement())
  shop        String   // Shop domain that owns this response
  email       String
  answers     String   @db.LongText
  surveyTitle String?
  shopDomain  String?  // Customer's shop domain (if different)
  orderId     String?
  createdAt   DateTime @default(now())

  @@index([shop])
  @@index([orderId])
}

// ─── NEW: tracks active billing plan per shop ─────────────────
model ShopPlan {
  id                   Int       @id @default(autoincrement())
  shop                 String    @unique        // one plan record per shop
  plan                 String    @default("free") // "free" | "pro" | "advanced"
  subscriptionId       String?                  // Shopify AppSubscription GID
  status               String    @default("active") // "active" | "cancelled" | "expired"
  trialEndsAt          DateTime?                // when trial expires
  billingStartedAt     DateTime?                // when paid billing began
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([shop])
}
